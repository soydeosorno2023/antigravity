# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# Firebase Client (Obtenido de la Consola de Firebase -> Configuración del Proyecto -> General -> Tus apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)

# Firebase Admin (Para el Servidor de Node.js en Hostinger)
# Se genera en Project Settings -> Service Accounts -> Generate new private key
# Pega el contenido del JSON como una cadena de texto en una sola línea (o en Hostinger ponlo tal cual)
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'

# Configuración de Servidor
PORT=8080
NODE_ENV=production
APP_URL=https://tu-dominio-en-hostinger.com

# Instagram API (Facebook Developers)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Correo (SMTP) para Notificaciones
SMTP_HOST=mail.soydeosorno.cl
SMTP_PORT=465
SMTP_USER=notificaciones@tu-dominio.com
SMTP_PASS=
ADMIN_EMAIL=
